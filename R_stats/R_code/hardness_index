library(dplyr)
library(ggplot2)
library(sandwich)
library(lmtest)

marathon_colours <- c(Berlin = "#F8766D", Boston = "#B79F00", Chicago = "#00BA38",
                      London = "#00BFC4", `New York` = "#619CFF", Tokyo = "#F564E3")
fmt_hm <- function(x) sprintf("%d:%02d", x %/% 60, round(x %% 60))

# --- Build: race-level hardness, corrected (rank-based net elevation) ---
race_hardness <- all_majors %>%
  left_join(hill_score, by = "Marathon") %>%
  left_join(race_weather, by = c("Marathon", "Year")) %>%
  filter(!is.na(temp_c), !is.na(wind_ms)) %>%
  mutate(temp_dev = abs(temp_c - 10),
        rank_net = rank(abs(net_m)),
        hardness = scale(gain_m)[,1] + scale(rank_net)[,1] +
                   scale(temp_dev)[,1] + scale(wind_ms)[,1])

# --- Stats: hardness vs time, no pacemaker control ---
for (s in c("M", "F")) {
  mod <- lm(avg_top10_seconds ~ Year + hardness, data = filter(race_hardness, Sex == s))
  cat("\n---", s, "---\n")
  print(coeftest(mod, vcov = vcovCL, cluster = ~Marathon)["hardness", ])
}

# --- Graph: hardness vs time ---
ggplot(race_hardness, aes(hardness, avg_top10_seconds / 60)) +
  geom_point(aes(colour = Marathon), alpha = 0.6, size = 2) +
  geom_smooth(aes(linetype = Sex), method = "lm", se = TRUE,
             colour = "black", fill = "grey50", alpha = 0.15, linewidth = 0.8) +
  facet_wrap(~Sex, scales = "free_y", labeller = as_labeller(c(M = "Men", F = "Women"))) +
  scale_colour_manual(values = marathon_colours) +
  scale_linetype_manual(values = c(M = "dashed", F = "dashed"), guide = "none") +
  scale_x_continuous(expand = expansion(mult = 0.05)) +
  scale_y_continuous(labels = fmt_hm, expand = expansion(mult = 0.05)) +
  labs(title = "Combined course hardness index vs elite finish time",
       subtitle = "Hardness = terrain + that year's conditions | Black dashed: linear fit with 95% CI",
       x = "Combined course hardness index(z-scored components)", y = "Avg top-10 time (h:mm)",
       colour = NULL) +
  theme_classic(base_size = 13) +
  theme(plot.title = element_text(face = "bold"), legend.position = "bottom")

