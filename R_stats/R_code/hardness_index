  left_join(course_weather, by = "Marathon") %>%
  mutate(temp_dev = abs(avg_temp - 10),   # distance from ~10°C optimum (sports-science consensus)
         hardness = scale(gain_m)[,1] + scale(abs(net_m))[,1] +
                    scale(temp_dev)[,1] + scale(avg_wind)[,1]) %>%
  arrange(desc(hardness))

hardness_static %>% select(Marathon, gain_m, net_m, avg_temp, avg_wind, hardness)

ggplot(hardness_static, aes(reorder(Marathon, hardness), hardness, fill = Marathon)) +
