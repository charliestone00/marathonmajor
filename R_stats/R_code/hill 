# Hill score vs winning time and top 10 

library(dplyr)
library(tidyr)
library(ggplot2)
library(ggrepel)

marathon_colours <- c(Berlin = "#F8766D", Boston = "#B79F00", Chicago = "#00BA38",
                      London = "#00BFC4", `New York` = "#619CFF", Tokyo = "#F564E3")

fmt_hm <- function(x) sprintf("%d:%02d", x %/% 60, round(x %% 60))

course_time_level <- all_majors %>%
  group_by(Marathon, Sex) %>%
  summarise(mean_top10 = mean(avg_top10_seconds),
           mean_winning = mean(winning_seconds), .groups = "drop") %>%
  left_join(hill_score, by = "Marathon") %>%
  pivot_longer(cols = c(mean_top10, mean_winning), names_to = "Metric", values_to = "time_sec") %>%
  mutate(Metric = case_when(
    Metric == "mean_top10" ~ "Top-10 average",
    Metric == "mean_winning" ~ "Winning time"
  ))

plot_hill_score <- function(data, sex_code, sex_label) {
  ggplot(filter(data, Sex == sex_code), aes(hill_score_z, time_sec / 60)) +
    geom_smooth(aes(linetype = Metric), method = "lm", se = FALSE, colour = "black", linewidth = 0.7) +
    geom_point(aes(colour = Marathon, shape = Metric), size = 3.5) +
    geom_text_repel(aes(label = Marathon), size = 3.3, colour = "black",
                    segment.color = NA, direction = "y", nudge_y = -0.4,
                    hjust = 0.5, max.overlaps = Inf, show.legend = FALSE) +
    scale_colour_manual(values = marathon_colours) +
    scale_shape_manual(values = c("Top-10 average" = 16, "Winning time" = 17)) +
    scale_x_continuous(expand = expansion(mult = 0.1)) +
    scale_y_continuous(labels = fmt_hm, expand = expansion(mult = 0.1)) +
    labs(title = paste("Combined hill score vs elite finish time —", sex_label),
        x = "Hill score (z-scored)", y = "Finish time (h:mm)",
        colour = NULL, shape = NULL, linetype = NULL) +
    theme_classic(base_size = 13) +
    theme(plot.title = element_text(face = "bold"), legend.position = "bottom")
}

plot_hill_score(course_time_level, "M", "Men")

plot_hill_score(course_time_level, "F", "Women")

