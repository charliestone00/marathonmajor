get_race_weather <- function(marathon, year, race_date) {
  empty <- data.frame(Marathon = marathon, Year = year, temp_c = NA_real_, wind_ms = NA_real_)
  if (is.na(race_date)) return(empty)
  actual_year <- as.integer(format(race_date, "%Y"))   # use the REAL year of the date, not the nominal Year
  met <- tryCatch(importNOAA(code = station_codes[[marathon]], year = actual_year), error = function(e) NULL)
  if (is.null(met) || nrow(met) == 0) return(empty)
  day_data <- met %>% filter(as.Date(date) == race_date, format(date, "%H") %in% sprintf("%02d", 9:13))
  if (nrow(day_data) == 0) return(empty)
  data.frame(Marathon = marathon, Year = year,
             temp_c = mean(day_data$air_temp, na.rm = TRUE),
             wind_ms = mean(day_data$ws, na.rm = TRUE))
}

