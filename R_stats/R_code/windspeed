### meaning 

## "Race-day wind speed showed a significant unadjusted correlation with women's finish times (r = 0.19, p = 0.026), but this association did not survive controlling for course and year (p = 0.117), indicating the raw correlation substantially reflects which courses tend to be both windier and structurally slower — most notably Boston — rather than a direct effect of wind on performance. Men showed a similar pattern in both specifications, with the effect remaining borderline (p ≈ 0.06–0.07) either way."

# Robustness check

library(sandwich)
library(lmtest)

wind_mod_m <- lm(avg_top10_seconds ~ Year + Marathon + wind_ms_centered, data = wind_m)
wind_mod_f <- lm(avg_top10_seconds ~ Year + Marathon + wind_ms_centered, data = wind_f)

# Clustered by course — same approach used on your other headline findings
coeftest(wind_mod_m, vcov = vcovCL, cluster = ~Marathon)["wind_ms_centered", ]
coeftest(wind_mod_f, vcov = vcovCL, cluster = ~Marathon)["wind_ms_centered", ]

# Newey-West as a second check, since these are also mildly time-ordered series
coeftest(wind_mod_m, vcov = NeweyWest(wind_mod_m))["wind_ms_centered", ]
coeftest(wind_mod_f, vcov = NeweyWest(wind_mod_f))["wind_ms_centered", ]

