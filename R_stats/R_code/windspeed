# Wind Speed x Time Graph
library(dplyr)
library(ggplot2)

wx_wind <- wx %>% filter(!is.na(wind_ms))

wx_wind <- wx_wind %>%
  group_by(Sex) %>%
  mutate(wind_ms_centered = wind_ms - mean(wind_ms, na.rm = TRUE)) %>%
  ungroup()

wind_m <- wx_wind %>% filter(Sex == "M")
wind_f <- wx_wind %>% filter(Sex == "F")

gmod_wind_m <- lm(avg_top10_seconds ~ Year + Marathon + wind_ms_centered, data = wind_m)
gmod_wind_f <- lm(avg_top10_seconds ~ Year + Marathon + wind_ms_centered, data = wind_f)

wind_range <- function(d) seq(min(d$wind_ms_centered, na.rm = TRUE), max(d$wind_ms_centered, na.rm = TRUE), length.out = 100)

pred_wind_m <- data.frame(wind_ms_centered = wind_range(wind_m), Year = mean(wind_m$Year), Marathon = "Berlin")
pred_wind_m <- cbind(pred_wind_m, predict(gmod_wind_m, newdata = pred_wind_m, se.fit = TRUE)[1:2]) %>%
  mutate(Sex = "M", lwr = fit - 1.96*se.fit, upr = fit + 1.96*se.fit)

pred_wind_f <- data.frame(wind_ms_centered = wind_range(wind_f), Year = mean(wind_f$Year), Marathon = "Berlin")
pred_wind_f <- cbind(pred_wind_f, predict(gmod_wind_f, newdata = pred_wind_f, se.fit = TRUE)[1:2]) %>%
  mutate(Sex = "F", lwr = fit - 1.96*se.fit, upr = fit + 1.96*se.fit)

pred_wind_all <- bind_rows(pred_wind_m, pred_wind_f)

wind_m$adj_time <- residuals(lm(avg_top10_seconds ~ Year + Marathon, data = wind_m)) + mean(wind_m$avg_top10_seconds)
wind_f$adj_time <- residuals(lm(avg_top10_seconds ~ Year + Marathon, data = wind_f)) + mean(wind_f$avg_top10_seconds)

